# Configurações do Backend (Supabase)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Se usar Supabase:
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# URL de Pooling (usado para as operações da aplicação)
DATABASE_URL="postgresql://postgres.[SEU_ID]:[SUA_PASSWORD]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL Direto (usado para migrações do Prisma)
DIRECT_URL="postgresql://postgres.[SEU_ID]:[SUA_PASSWORD]@aws-0-[REGIAO].pooler.supabase.com:5432/postgres"

# Mapbox Configuration
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token

# Firebase Admin (server-only) — para enviar notificações push (FCM) quando
# uma ocorrência muda de estado. Sem estas 3 variáveis, a app continua a
# funcionar normalmente, só que sem enviar pushes (fica só a notificação
# in-app). Obter em: Firebase Console -> ⚙️ Definições do projeto ->
# Contas de serviço -> "Gerar nova chave privada" (descarrega um ficheiro
# JSON com estes 3 campos: project_id, client_email, private_key).
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Cole a private_key do JSON tal como vem (com as quebras de linha "\n"
# escapadas) — o código em src/core/env.ts trata de as "desescapar".
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# Gemini (Google AI) — usado só no servidor, para a verificação de resolução
# por IA (compara a foto original com a foto de resolução). NUNCA usar o
# prefixo NEXT_PUBLIC_ para esta chave — variáveis NEXT_PUBLIC_ são
# inseridas no bundle JavaScript enviado ao browser, e esta é uma chave
# paga que deve ficar exclusivamente no servidor.
GEMINI_API_KEY=your_gemini_api_key




